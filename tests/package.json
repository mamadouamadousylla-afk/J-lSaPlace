{
  "name": "sunulamb-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for SunuLamb application",
  "main": "e2e/run-tests.js",
  "scripts": {
    "test": "node e2e/run-tests.js",
    "test:jest": "jest e2e/*.test.js --verbose",
    "test:headed": "HEADLESS=false node e2e/run-tests.js",
    "test:debug": "HEADLESS=false SLOWMO=50 node e2e/run-tests.js"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "puppeteer": "^21.0.0"
  },
  "jest": {
    "preset": "jest-puppeteer",
    "testTimeout": 30000,
    "setupFilesAfterEnv": ["./e2e/setup.js"],
    "testMatch": [
      "**/e2e/**/*.test.js"
    ]
  }
}