{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff HEAD~1 --quiet -- . ':(exclude)package-lock.json' ':(exclude)package.json'",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "fix/production-build": true
    }
  }
}
